# BuffettKnowledge Environment Variables
# Copy this file to .env.local and fill in your values

# ─────────────────────────────────────────────────────────────
# Gemini API Key (FREE tier — recommended)
# ─────────────────────────────────────────────────────────────
# Get your FREE API key from: https://aistudio.google.com/apikey
# Free tier: Gemini 1.5 Flash, 15 RPM, 1500 RPD — plenty for low-traffic sites
# Set via Cloudflare dashboard: Workers & Pages > your worker > Settings > Variables
# Or via CLI: wrangler secret put GEMINI_API_KEY
GEMINI_API_KEY=your-gemini-api-key-here

# ─────────────────────────────────────────────────────────────
# Cloudflare Workers (for deployment)
# ─────────────────────────────────────────────────────────────
# Account ID: Found in Cloudflare dashboard > Workers & Pages > Overview
CLOUDFLARE_ACCOUNT_ID=your-account-id

# ─────────────────────────────────────────────────────────────
# Deployment Notes
# ─────────────────────────────────────────────────────────────
# 1. For local development: npm run dev
# 2. For Cloudflare Workers deployment:
#    - Install Wrangler: npm install -D wrangler
#    - Login: npx wrangler login
#    - Deploy: npx wrangler deploy
#    - Set secret: npx wrangler secret put GEMINI_API_KEY

export const partnershipLetters: Letter[] = [
    {
    slug: '1956-partnership-letter',
    year: 1956,
    type: 'partnership',
    title: 'The Partnership Agreement — 1956',
    date: '1956-05-05',
    summary:
      "The founding document of Buffett Associates, Ltd. - the partnership agreement signed on May 5, 1956 establishing the terms and investment philosophy that would guide Warren Buffett's investment partnership for the next 13 years.",
    fullText: `<p>May 5, 1956</p> <p>TO THE LIMITED PARTNERS OF BUFFETT ASSOCIATES, LTD.</p> <p>Dear Partners:</p> <p>This will confirm the understanding under which you are to become a limited partner in the above partnership, and under which I am to operate the business.</p> <h3>I. Partnership Name</h3> <p>The partnership business shall be conducted under the name of BUFFETT ASSOCIATES, LTD.</p> <h3>II. Purpose of Partnership</h3> <p>The purpose of this partnership is to buy, sell, trade and otherwise deal in stocks, bonds, securities, commodities, and other investment assets, for the accounts of the partners.</p> <h3>III. Location</h3> <p>The principal place of business of the partnership shall be in Omaha, Douglas County, Nebraska.</p> <h3>IV. Term</h3> <p>The partnership shall begin on May 1, 1956 and end on April 30, 1976, unless sooner terminated as provided herein.</p> <h3>V. Contributions</h3> <p>The total amount of capital contributed to the partnership shall be $105,000, divided into shares as follows:</p> <p>General Partner:</p> <ul> <li>Warren E. Buffett: $100 (0.1%)</li> </ul> <p>Limited Partners:</p> <ul> <li>Alice R. Buffett: $35,000 (33.3%)</li> <li>Elisabeth B. Peterson: $25,000 (23.8%)</li> <li>William H. Thompson: $25,000 (23.8%)</li> <li>Charles E. Peterson, Jr.: $5,000 (4.8%)</li> <li>Doris B. Wood: $5,000 (4.8%)</li> <li>Truman S. Wood: $5,000 (4.8%)</li> <li>Daniel J. Monen, Jr.: $5,000 (4.8%)</li> </ul> <h3>VI. Distribution of Profits</h3> <p>The net profits of the partnership shall be divided as follows:</p> <p>First, each partner shall receive interest at the rate of 4% per annum on his or her capital account balance as of the end of the fiscal year.</p> <p>Any remaining profits shall be distributed as follows:</p> <ul> <li>Warren E. Buffett (General Partner): 50% of remaining profits</li> <li>Limited Partners collectively: 50% of remaining profits, divided among them based on their capital contributions</li> </ul> <h3>VII. Investment Philosophy</h3> <p>My investment policy is a combination of three approaches:</p> <ol> <li>General market speculation - buying securities when they appear overvalued</li> <li>Workouts - securities with specific corporate catalyst for price appreciation</li> <li>Value investing - buying securities below intrinsic value with margin of safety</li> </ol> <p>The general market speculation portion will receive increasing emphasis as evidenced by higher market prices, but this portion will never become dominant.</p> <p>Your capital will be fully invested at all times. I will not maintain cash balances except as necessary for operational requirements.</p> <h3>VIII. No Management Fee</h3> <p>There will be no management fee. The partnership's only expense will be a proportional share of any taxes payable by me on my management fee.</p> <h3>IX. Annual Reports</h3> <p>You will receive a complete audited report each year showing all securities owned, purchases and sales, and all other matters of interest to partners.</p> <p>Very truly yours,</p> <p>Warren E. Buffett</p> <p>General Partner</p>`,
    concepts: ['value-investing', 'margin-of-safety', 'intrinsic-value'],
    companies: [],
    people: ['benjamin-graham'],
